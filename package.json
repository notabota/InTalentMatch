{
  "name": "intalentmatch_frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:smoke": "bash scripts/smoke.sh",
    "test:mutation": "stryker run",
    "test:perf:read": "k6 run tests/perf/read.k6.js",
    "test:perf:write": "k6 run tests/perf/write.k6.js",
    "test:perf:cron": "k6 run tests/perf/cron.k6.js",
    "db:erd": "ERD_DISABLED=false prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/react-dom": "^18.3.6",
    "bcryptjs": "^3.0.3",
    "cleave.js": "^1.6.0",
    "dayjs": "^1.11.13",
    "jose": "^6.2.3",
    "lucide-react": "^0.487.0",
    "next": "15.2.4",
    "postmark": "^4.0.7",
    "react": "^19.0.0",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "recharts": "^2.15.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@playwright/test": "^1.60.0",
    "@sentry/nextjs": "^10.53.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.13.17",
    "@types/react": "^18.3.20",
    "@types/react-input-mask": "^3.0.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "9.24.0",
    "eslint-config-next": "15.3.0",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "prisma-erd-generator": "^2.4.2",
    "puppeteer-core": "^25.0.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.0",
    "typescript": "5.8.2",
    "vitest": "^4.1.6"
  }
}
